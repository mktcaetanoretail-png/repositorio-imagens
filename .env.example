APP_NAME="Repositório de Imagens"
APP_URL=https://repositorio-imagens.vercel.app
APP_ENV=production
APP_DEBUG=false

# Driver: pgsql (Supabase/Vercel) | mysql (MariaDB produção)
DB_DRIVER=pgsql
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=
# Supabase exige SSL. Para MariaDB local usar: disable
DB_SSLMODE=require

# Em Vercel o filesystem é efémero — usar /tmp/images para testes
# Em produção (MariaDB + servidor próprio): caminho absoluto gravável pelo web server
STORAGE_PATH=/tmp/images

SESSION_LIFETIME=7200
REMEMBER_ME_DAYS=30

UPLOAD_MAX_SIZE_MB=20
UPLOAD_MAX_FILES=20
